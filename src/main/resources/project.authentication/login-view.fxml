<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="project.authentication.AuthController" spacing="30">
    <padding>
        <Insets top="50" left="50" right="50" bottom="50"/>
    </padding>
    <HBox alignment="CENTER" spacing="30">
        <VBox spacing="10.0">
            <Label fx:id="slotsLabel"/>
            <Label text="Select your Username below:"/>
            <ListView fx:id="usersListView"/>
        </VBox>
        <VBox alignment="BOTTOM_CENTER" spacing="10.0">
            <HBox alignment="CENTER_RIGHT">
                <Label text="Enter your details here:"/>
            </HBox>
            <GridPane hgap="10.0" vgap="10.0">
                <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="usernameTextField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>
            <Region prefHeight="20"/>
            <HBox spacing="30.0" alignment="CENTER_RIGHT">
                <Button fx:id="registerBtn"
                        onAction="#registerBtnClick"
                />
            </HBox>
        </VBox>
    </HBox>
</VBox>