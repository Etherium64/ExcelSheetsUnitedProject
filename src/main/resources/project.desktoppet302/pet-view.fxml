<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Text?>

<HBox fx:id="box" xmlns:fx="http://javafx.com/fxml"
      fx:controller="project.desktoppet302.PetController"
      style="-fx-background-color: white;" spacing="20">
    <ImageView fx:id="petImage" preserveRatio="true" fitWidth="200" fitHeight="200"
               onMouseClicked="#onImageClick" onMouseDragged="#onImageDrag"
               onMouseReleased="#onDragExit" >
        <Image fx:id="pet" url="@/AnimationStates"/>
    </ImageView>
</HBox>
