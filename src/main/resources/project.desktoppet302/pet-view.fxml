<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox fx:id="hbox"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="project.desktoppet302.PetController"
      stylesheets="@/styles.css"
      style="-fx-background-color: transparent">

    <VBox fx:id="optionsBox"
          visible="false"
          managed="false"
          minWidth="150"
          spacing="15"
          translateX="5"
          translateY="25">

        <Button fx:id="timer"
                styleClass="button1"
                text="Pomodoro"
                minWidth="150"
                minHeight="50"
                onAction="#pomodoroButton"/>

        <Button fx:id="trivia"
                styleClass="button1"
                text="Trivia"
                minWidth="150"
                minHeight="50"
                onAction="#triviaButton"/>

        <Button styleClass="button1"
                text="Settings"
                minWidth="150"
                minHeight="50"/>
    </VBox>

    <VBox fx:id="imagebox">

        <VBox fx:id="optionsBox"
              visible="false"
              managed="false"
              alignment="CENTER"
              spacing="8"
              translateY="-170">

            <Button fx:id="timer"
                    styleClass="button1"
                    text="Pomodoro"
                    minWidth="150"
                    minHeight="50"
                    onAction="#pomodoroButton"/>

            <Button fx:id="trivia"
                    styleClass="button1"
                    text="Trivia"
                    minWidth="150"
                    minHeight="50"
                    onAction="#triviaButton"/>

            <Button styleClass="button1"
                    text="Settings"
                    minWidth="150"
                    minHeight="50"/>
        </VBox>

        <Text fx:id="pettext"
              styleClass="text-field"
              text="lol"
              wrappingWidth="200"
              textAlignment="CENTER"
              visible="false"
              managed="false"/>

        <HBox alignment="CENTER"
              translateY="10"
              spacing="5">

            <Button fx:id="yesbutton"
                    styleClass="button2"
                    text="Yes"
                    minWidth="50"
                    visible="false"
                    managed="false"
                    onAction="#goButton"/>

            <Button fx:id="nobutton"
                    styleClass="button2"
                    text="No"
                    minWidth="50"
                    visible="false"
                    managed="false"
                    onAction="#returnButton"/>
        </HBox>

        <ImageView fx:id="petImage"
                   preserveRatio="true"
                   fitWidth="175"
                   fitHeight="175"
                   onMouseClicked="#onImageClick"
                   onMouseDragged="#onImageDrag">

            <Image fx:id="pet" url="@/AnimationStates"/>
        </ImageView>

    </VBox>

</HBox>