<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:id="hbox"
      fx:controller="project.desktoppet302.PetController"
      stylesheets="@/styles.css"
      style="-fx-background-color: transparent">
    <VBox minWidth="150" spacing="5" translateX="5" translateY="5">
        <Button
                fx:id="pomodoro"
                styleClass="button1"
                text="Timer"
                minWidth="150"
                minHeight="70"
                onAction="#pomodoroButton"/>
        <Button fx:id="trivia"
                styleClass="button1"
                text="Trivia"
                minWidth="150"
                minHeight="70"
                onAction="#triviaButton"/>
        <Button fx:id="logout"
                styleClass="button1"
                text="Log Out"
                minWidth="150"
                minHeight="70"
                onAction="#logoutButton"
        />
    </VBox>
    <VBox fx:id="imageBox">

        <TextField fx:id="textField"
                   styleClass="text-field"
                   visible="false"
                   minWidth="250"
                   translateX="-40"
                   alignment="BOTTOM_CENTER"
        >
            <Text fx:id="petText"
                  styleClass="text-field"
                  text=""
                  wrappingWidth="240"
                  textAlignment="CENTER"
                  visible="true"
                  managed="true"
            />
        </TextField>


        <HBox fx:id="promptButtons"
              alignment="CENTER"
              spacing="5"
              visible="false"
              managed="true"
              translateX="-45"
        >

            <Button fx:id="yesbutton"
                    styleClass="button2"
                    text="Yes"
                    minWidth="50"
                    onAction="#goButton"/>

            <Button fx:id="nobutton"
                    styleClass="button2"
                    text="No"
                    minWidth="50"
                    maxHeight="15"
                    onAction="#returnButton"/>
        </HBox>
        <ImageView fx:id="petImage"
                   preserveRatio="true"
                   fitWidth="175"
                   fitHeight="175"
        >

            <Image fx:id="pet" url="@/AnimationStates"/>
        </ImageView>


    </VBox>

</HBox>
