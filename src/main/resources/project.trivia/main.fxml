<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="185.0" prefWidth="218.0" spacing="15" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="project.Trivia.MainController">

    <Label style="-fx-font-size: 15px; -fx-font-weight: bold;" />

    <GridPane fx:id="triviaSection" alignment="CENTER" prefHeight="125.0" prefWidth="179.0">
        <children>
            <Label fx:id="questionLabel" style="-fx-font-size: 12px; -fx-text-fill: black;" text="Loading..." GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.rowIndex="0" GridPane.valignment="CENTER" />

            <Button fx:id="buttonA" onAction="#onAnswerClick" prefHeight="20" prefWidth="85" style="-fx-font-size: 9px; -fx-ellipsis-string: '';" text="Option A" wrapText="true" GridPane.columnIndex="0" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER" />

            <Button fx:id="buttonB" onAction="#onAnswerClick" prefHeight="20" prefWidth="85" style="-fx-font-size: 9px; -fx-ellipsis-string: '';" text="Option B" wrapText="true" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER" />

            <Button fx:id="buttonC" onAction="#onAnswerClick" prefHeight="20" prefWidth="85" style="-fx-font-size: 9px; -fx-ellipsis-string: '';" text="Option C" wrapText="true" GridPane.columnIndex="0" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" />

            <Button fx:id="buttonD" onAction="#onAnswerClick" prefHeight="20" prefWidth="85" style="-fx-font-size: 9px; -fx-ellipsis-string: '';" text="Option D" wrapText="true" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER" />
        </children>
        <columnConstraints>
            <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="85" />
            <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="85" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>
    <Button fx:id="EndButton" alignment="CENTER" onAction="#endTrivia" text="End" />



    <!-- Username Section (hidden at start) -->
    <VBox fx:id="usernameSection" managed="false" visible="false">
        <Button onAction="#onSaveClick" text="Save Score" />
        <Button onAction="#dontSave" text="Don't Save" />
    </VBox>
    <HBox alignment="CENTER" spacing="10">
        <Label text="Username: " />
        <Label fx:id="usernameLabel"/>
    </HBox>
    <Label text="Score:" />
    <Label fx:id="scoreLabel" style="-fx-font-size: 18px;" text="0" />
    <Label fx:id="statusLabel" text="" />

</VBox>
