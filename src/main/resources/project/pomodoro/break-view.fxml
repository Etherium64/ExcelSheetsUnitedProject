<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<?import javafx.scene.layout.StackPane?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="project.pomodoro.ButtonController">
    <VBox alignment="CENTER" spacing="30.0" fillWidth="false">
        <HBox spacing="100.00" alignment="CENTER">
            <Button fx:id="pomoBtn"
                    text="Pomodoro"
                    onAction="#pomoBtnClick"
            />
            <Button fx:id="scoreBtn" text="Score"/>
        </HBox>

        <HBox spacing="20.0" alignment="CENTER">
            <Label fx:id="timerLabel"/>
        </HBox>

        <HBox spacing="100.0" alignment="CENTER">
            <Button fx:id="switchBtn"
                    text="Start"
                    onAction="#switchBtnClick"
            />
            <Button fx:id="resetBtn"
                    text="Reset"
                    onAction ="#resetBtnClick"
            />
        </HBox>
    </VBox>
</StackPane>