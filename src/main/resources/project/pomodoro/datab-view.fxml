<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="project.pomodoro.controller.PomodoroController">
    <padding>
        <Insets left="20" right="20" bottom="50"/>
    </padding>
    <top>
        <HBox spacing="50.0">
            <Button fx:id="returnBtn"
                onAction="#returnBtnClick">
            </Button>
        </HBox>
    </top>
    <center>
        <TableView fx:id="tableView" editable="true" maxHeight="800">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="idCol" text="Id ">
                </TableColumn>
                <TableColumn fx:id="timestampCol" text="Timestamp">
                </TableColumn>
                <TableColumn fx:id="typeCol" text="Session">
                </TableColumn>
                <TableColumn fx:id="taskCol" text="Task">
                </TableColumn>
                <TableColumn fx:id="timespentCol" text="Time Spent">
                </TableColumn>
                <TableColumn fx:id="completionCol" text="Completed?">
                </TableColumn>
            </columns>
            <sortOrder>
                <fx:reference source="idCol"/>
            </sortOrder>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="100.0" alignment="CENTER">
            <Button
                    text="CREATE"
                    onAction="#createBtnClick"
            />
            <Button
                    text="DELETE"
                    onAction="#deleteBtnClick"
            />
        </HBox>
    </bottom>
</BorderPane>





