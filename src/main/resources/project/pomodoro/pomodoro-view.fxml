<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>

<?import javafx.scene.layout.StackPane?>

<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.Region?>
<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="project.pomodoro.ButtonController">
    <VBox alignment="CENTER" spacing="50.0" fillWidth="false">
        <HBox spacing="120.00" alignment="CENTER">
            <Button fx:id="breakBtn"
                    text="Break"
                    onAction="#breakBtnClick"
            />
            <Button fx:id="scoreBtn" text="Score"/>
        </HBox>

        <VBox alignment="CENTER">
            <Label fx:id="timerLabel"/>
            <ProgressBar fx:id="pB"/>
            <Region prefHeight="100" />
        </VBox>

        <HBox spacing="120.0" alignment="CENTER">
            <Button fx:id="switchBtn"
                        text="Start"
                        onAction="#switchBtnClick"/>
            <Button fx:id="resetBtn"
                        text="Reset"
                        onAction="#resetBtnClick"
            />
        </HBox>
    </VBox>
</StackPane>


