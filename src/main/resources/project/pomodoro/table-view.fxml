<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="project.pomodoro.controller.PomodoroController">
    <padding>
        <Insets bottom="300" top="30" left="30" right="30"/>
    </padding>
    <center>
        <TableView id="tableView" fx:id="tableView">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="idCol" text="Id ">
                </TableColumn>
                <TableColumn fx:id="timestampCol" text="Timestamp">
                </TableColumn>
                <TableColumn fx:id="typeCol" text="Session">
                </TableColumn>
                <TableColumn fx:id="taskCol" text="Task">
                </TableColumn>
                <TableColumn fx:id="timespentCol" text="Time Spent">
                </TableColumn>
                <TableColumn fx:id="completionCol" text="Completed?">
                </TableColumn>
            </columns>
            <sortOrder>
                <fx:reference source="idCol"/>
            </sortOrder>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER">
            <Button fx:id="backBtn"
                    text="Go Back"
                    onAction="#backBtnClick"
            />
        </HBox>
    </bottom>
</BorderPane>



