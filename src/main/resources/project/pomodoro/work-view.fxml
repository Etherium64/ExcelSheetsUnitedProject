<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="project.pomodoro.WorkController">
    <padding>
        <Insets left="100" right="100"/>
    </padding>
    <left>
        <VBox alignment="CENTER" spacing="50">
            <fx:define>
                <ToggleGroup fx:id="workGroup"/>
            </fx:define>
            <RadioButton fx:id="rBtn1"
                         text="Programming"
                         toggleGroup="$workGroup"
                         selected="true">
            </RadioButton>
            <RadioButton fx:id="rBtn2"
                         text="Assigned Readings"
                         toggleGroup="$workGroup">
            </RadioButton>
            <RadioButton fx:id="rBtn3"
                         text="Watch Lecture"
                         toggleGroup="$workGroup">
            </RadioButton>
            <RadioButton fx:id="rBtn4"
                         text="Housekeeping"
                         toggleGroup="$workGroup">
            </RadioButton>
        </VBox>
    </left>

    <right>
        <VBox alignment="CENTER">
            <HBox spacing="150.0" alignment="CENTER">
                <Button fx:id="breakBtn"
                        text="BREAK"
                        onAction="#breakBtnClick"
                />
                <Button fx:id="databBtn"
                        text="DATABASE"
                        onAction="#databBtnClick"
                />
            </HBox>

            <VBox alignment="CENTER">
                <Region prefHeight="70"/>
                <Label fx:id="timerLabel"
                       text="25:00"/>
                <ProgressBar fx:id="timerBar"/>
                <Region prefHeight="100"/>
            </VBox>

            <HBox spacing="150.0" alignment="CENTER">
                <Button fx:id="startPauseBtn"
                        text="START"
                        onAction="#startPauseBtnClick"/>
                <Button fx:id="resetBtn"
                        text="RESET"
                        onAction="#resetBtnClick"
                />
            </HBox>
        </VBox>
    </right>
</BorderPane>



