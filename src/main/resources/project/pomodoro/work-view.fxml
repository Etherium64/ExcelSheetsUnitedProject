<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="project.pomodoro.WorkController">
    <padding>
        <Insets left="20" right="20" top="20" bottom="20"/>
    </padding>
    <left>
        <VBox alignment="CENTER" spacing="50">
            <fx:define>
                <ToggleGroup fx:id="workGroup"/>
            </fx:define>
            <RadioButton fx:id="rBtn1"
                         text="Programming"
                         toggleGroup="$workGroup"
                         selected="true">
            </RadioButton>
            <RadioButton fx:id="rBtn2"
                         text="Assigned Readings"
                         toggleGroup="$workGroup">
            </RadioButton>
            <RadioButton fx:id="rBtn3"
                         text="Watch Lecture"
                         toggleGroup="$workGroup">
            </RadioButton>
            <RadioButton fx:id="rBtn4"
                         text="Housekeeping"
                         toggleGroup="$workGroup">
            </RadioButton>
        </VBox>
    </left>

    <right>
        <VBox alignment="CENTER">
            <HBox spacing="100.0" alignment="CENTER">
                <Button fx:id="databBtn"
                        text="DATABASE"
                        onAction="#databBtnClick"
                />
                <Button fx:id="closeBtn"
                        text="CLOSE"
                        onAction="#closeBtnClick"
                />
            </HBox>

            <VBox alignment="CENTER">
                <Region prefHeight="80"/>
                <HBox alignment="CENTER" spacing="10">
                    <Button fx:id="breakBtn"
                            text="BREAK"
                            onAction="#breakBtnClick"
                    />
                    <Label fx:id="timerLabel"
                           text="25:00"/>
                </HBox>
                <ProgressBar fx:id="timerBar"/>
                <Region prefHeight="80"/>
            </VBox>

            <HBox spacing="100.0" alignment="CENTER">
                <Button fx:id="startPauseBtn"
                        text="START"
                        onAction="#startPauseBtnClick"/>
                <Button fx:id="resetBtn"
                        text="RESET"
                        onAction="#resetBtnClick"
                />
            </HBox>
        </VBox>
    </right>
</BorderPane>



